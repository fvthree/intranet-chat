# Copy to .env or export when not using defaults from application.yml

APP_DB_HOST=localhost
# Default matches docker-compose (Postgres published on host port 5433). Use 5432 if your Postgres listens there.
APP_DB_PORT=5433
APP_DB_NAME=intranet_chat
APP_DB_USER=postgres
APP_DB_PASSWORD=postgres

APP_REDIS_HOST=localhost
APP_REDIS_PORT=6379

# Base64-encoded 32+ byte secret for HS256 (must match between login and resource server)
APP_JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
APP_JWT_ISSUER=intranet-chat
APP_JWT_EXPIRATION_SECONDS=3600

SERVER_PORT=8080
