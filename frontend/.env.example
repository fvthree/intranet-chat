# Optional: browser → API base URL (no trailing slash). Leave unset to use same-origin
# `/api/...` (Next.js proxies to the backend — avoids CORS in local dev).
# If set, WebSocket origin is derived from this URL. On loopback, if unset, the client uses
# ws(s)://<hostname>:8080 (direct to Spring).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: where Next proxies `/api` and `/ws` (server-side only). Default http://127.0.0.1:8080
# BACKEND_ORIGIN=http://127.0.0.1:8080

# Optional: force WebSocket origin. Prefer ws://127.0.0.1:8080 on Windows (localhost → IPv6 can miss the JVM).
# When unset, the client uses ws(s)://<same host as the page> (e.g. ws://localhost:3000/ws → proxied).
# NEXT_PUBLIC_WS_ORIGIN=ws://127.0.0.1:8080
