# Optional: browser → API base URL (no trailing slash). Leave unset to use same-origin
# `/api/...` (Next.js proxies to the backend — avoids CORS in local dev).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Optional: where Next proxies `/api` (server-side only). Default http://127.0.0.1:8080
# BACKEND_ORIGIN=http://127.0.0.1:8080
